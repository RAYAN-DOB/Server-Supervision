# ═══════════════════════════════════════════════════════════════════════════════
# AURION — Variables d'environnement
# DSI Ville de Maisons-Alfort
#
# ⚠ NE JAMAIS committer le fichier .env (données sensibles)
# Copier ce fichier en .env.local pour le développement
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Authentification (SERVEUR uniquement — OBLIGATOIRE) ─────────────────────

# Secret JWT — OBLIGATOIRE en production (min. 32 caractères)
# Générer avec : openssl rand -base64 32
AUTH_SECRET=changez-moi-en-production-minimum-32-caracteres!!

# Mot de passe par défaut pour tous les comptes DSI pré-configurés.
# Les utilisateurs peuvent le changer depuis leur profil.
# Normes : min. 8 caractères, majuscule, minuscule, chiffre, caractère spécial
INITIAL_DSI_PASSWORD=@zerty123456789

# ─── Zabbix API (SERVEUR uniquement) ──────────────────────────────────────────

# URL de l'API Zabbix JSON-RPC
ZABBIX_API_URL=http://192.168.X.X/zabbix/api_jsonrpc.php

# Token d'API Zabbix (Zabbix ≥ 5.4 — recommandé)
# Créer dans : Administration → API tokens → Create token
ZABBIX_API_TOKEN=votre_token_api_ici

# Alternative user/password si pas de token API
# ZABBIX_USER=Admin
# ZABBIX_PASSWORD=votre_mot_de_passe

# ─── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=AURION
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Production (Netlify) ─────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://votre-domaine.netlify.app
#
# Variables à définir dans : Netlify → Site configuration → Environment variables
# - AUTH_SECRET           (openssl rand -base64 32)
# - INITIAL_DSI_PASSWORD  (mot de passe temporaire fort)
# - ZABBIX_API_URL        (URL de votre serveur Zabbix)
# - ZABBIX_API_TOKEN      (token API Zabbix)
# - NEXT_PUBLIC_APP_URL   (URL publique du site)
# - NODE_ENV=production   (automatiquement défini par Netlify)
